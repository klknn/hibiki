namespace hibiki.ipc;

table ParamInfo {
    id: uint;
    name: string;
    default_value: float;
}

table ParamList {
    track_index: int;
    plugin_index: int;
    plugin_name: string;
    is_instrument: bool;
    params: [ParamInfo];
}

table Log {
    message: string;
}

table Acknowledge {
    command_type: string;
    success: bool;
}

table ClipInfo {
    track_index: int;
    slot_index: int;
    name: string;
    path: string;
}

table ClearProject {}

table TrackLevel {
    track_index: int;
    peak_l: float;
    peak_r: float;
}

table TrackLevels {
    levels: [TrackLevel];
}

table ClipWaveform {
    track_index: int;
    slot_index: int;
    waveform: [float];
}

table PluginDescription {
    index: int;
    name: string;
    vendor: string;
}

table PluginList {
    path: string;
    plugins: [PluginDescription];
}

union Response {
    ParamList,
    Log,
    Acknowledge,
    ClipInfo,
    ClearProject,
    TrackLevels,
    ClipWaveform,
    PluginList
}

table Notification {
    response: Response;
}

root_type Notification;
